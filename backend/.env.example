# Copy this file to .env and edit as needed.

ENV=development
API_KEY=dev-local-api-key
JWT_SECRET=change-me-in-production

DATABASE_URL=sqlite:///./gateway.db

RISK_BLOCK_THRESHOLD=60
RISK_WARN_THRESHOLD=30

DEFAULT_LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=llama3

# Only needed if you use provider=openai (or any OpenAI-compatible endpoint)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_DEFAULT_MODEL=gpt-4o-mini

# Groq: free-tier hosted open-source models — recommended for public demos.
# Get a free key at https://console.groq.com/keys
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_DEFAULT_MODEL=llama-3.1-8b-instant

# Public demo safety — set both when deploying publicly
DEMO_MODE=false
RATE_LIMIT_PER_MINUTE=20
